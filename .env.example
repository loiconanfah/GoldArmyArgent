# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama2

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./storage/chroma_db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./storage/logs/goldarmyargent.log

# Agent Configuration
MAX_AGENTS=10
AGENT_TIMEOUT=300
MAX_RETRIES=3

# System
DEBUG=False

# CORS (optionnel) : origine du front en prod, ex. https://ton-front.com
# CORS_ORIGIN=https://ton-front.com

# Auth (obligatoire en production)
JWT_SECRET_KEY=change-me-in-production

# Search API Keys
JOOBLE_API_KEY=

# RapidAPI Configuration (JSearch) — clés de secours en cas de 429
RAPIDAPI_KEY=
RAPIDAPI_KEY_2=
RAPIDAPI_KEY_3=
RAPIDAPI_HOST=jsearch.p.rapidapi.com

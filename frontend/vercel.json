{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://goldarmy.onrender.com/api/:path*"
        },
        {
            "source": "/auth/:path*",
            "destination": "https://goldarmy.onrender.com/auth/:path*"
        },
        {
            "source": "/:path*",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/sitemap.xml",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/xml; charset=utf-8"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400"
                }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/plain; charset=utf-8"
                }
            ]
        }
    ]
}